{
    "env": {
        "browser": true,
        "es2024": true,
        "jquery": true,
        "greasemonkey": true
    },
    "parserOptions": {
        "sourceType": "module"
    },
    "extends": [
        "eslint:recommended"
    ],
    "rules": {
        "eqeqeq": "error",
        "spaced-comment": "error",
        "no-unused-expressions": "error"
    }
}
